{
  "expo": {
    "name": "UniMarket",
    "slug": "unimarket",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.unimarket.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.unimarket.app"
    },
    "web": {},
    "plugins": [
      "expo-router"
    ],
    "scheme": "unimarket",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "3758e45d-e5f1-4923-815a-5157f577df78"
      }
    },
    "owner": "jaredvinnie"
  }
}

